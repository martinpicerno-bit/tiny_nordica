---
import { SITE } from '../data/site';
---

<footer class="footer">
  <div class="container footer__inner">
    <div class="footer__marca">
      <p class="footer__nombre">Tiny Granero</p>
      <p class="footer__ubicacion">{SITE.ubicacion}</p>
    </div>

    <nav class="footer__nav" aria-label="Redes y contacto">
      <a
        href={SITE.WHATSAPP_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="footer__link"
        aria-label="Escribirnos por WhatsApp"
        data-meta-event="Contact"
        data-meta-content="whatsapp_footer"
      >
        WhatsApp
      </a>
      <a
        href={SITE.INSTAGRAM_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="footer__link"
        aria-label="Seguirnos en Instagram"
        data-meta-event="custom:ViewInstagram"
        data-meta-content="instagram_footer"
      >
        Instagram
      </a>
      <a
        href={SITE.AIRBNB_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="footer__link"
        aria-label="Reservar en Airbnb"
        data-meta-event="Lead"
        data-meta-content="airbnb_footer"
      >
        Airbnb
      </a>
    </nav>

    <div class="footer__legal">
      <a
        href={SITE.POLITICA_PRIVACIDAD_URL}
        class="footer__link footer__link--sm"
      >
        Política de privacidad
      </a>
      <p class="footer__copy">{SITE.copyright}</p>
    </div>
  </div>
</footer>

<style>
.footer {
  background: var(--color-carbon);
  border-top: 1px solid rgba(201,185,154,0.1);
  padding-block: var(--sp-8);
}

.footer__inner {
  display: flex;
  flex-wrap: wrap;
  gap: var(--sp-6);
  align-items: center;
  justify-content: space-between;
}

.footer__nombre {
  font-family: var(--font-display);
  font-size: var(--text-lg);
  color: var(--color-roto);
  font-weight: 500;
  margin-bottom: 0.2em;
}

.footer__ubicacion {
  font-size: var(--text-xs);
  color: rgba(247,244,238,0.45);
  letter-spacing: 0.06em;
}

.footer__nav {
  display: flex;
  gap: var(--sp-4);
  flex-wrap: wrap;
}

.footer__link {
  font-size: var(--text-sm);
  color: var(--color-arena);
  transition: color var(--duration) var(--ease);
  font-weight: 500;
}

.footer__link:hover {
  color: var(--color-roto);
}

.footer__link--sm {
  font-size: var(--text-xs);
  opacity: 0.6;
}

.footer__legal {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: var(--sp-1);
}

.footer__copy {
  font-size: var(--text-xs);
  color: rgba(247,244,238,0.3);
}

@media (max-width: 640px) {
  .footer__inner {
    flex-direction: column;
    align-items: flex-start;
  }

  .footer__legal {
    align-items: flex-start;
  }
}
</style>
