---
import { SITE } from '../data/site';
import { PRECIOS } from '../content/landing';

const fmt = (n: number) =>
  new Intl.NumberFormat('es-CL', { style: 'currency', currency: 'CLP', maximumFractionDigits: 0 }).format(n);
---

{SITE.PRECIO_VISIBLE_EN_LANDING && (
  <section class="precios" id="precios" aria-labelledby="precios-titulo">
    <div class="container">
      <div class="section-header">
        <p class="eyebrow">{PRECIOS.eyebrow}</p>
        <h2 class="section-h2 section-h2--dark" id="precios-titulo">{PRECIOS.titulo}</h2>
      </div>

      <div class="precios__cards">
        <div class="precios__card">
          <p class="precios__label">Domingo a jueves</p>
          <p class="precios__monto">{fmt(SITE.precio_semana)}</p>
          <p class="precios__unidad">por noche</p>
        </div>
        <div class="precios__card precios__card--dest">
          <p class="precios__label">Fin de semana y feriados</p>
          <p class="precios__monto">{fmt(SITE.precio_finde)}</p>
          <p class="precios__unidad">por noche</p>
        </div>
      </div>

      <p class="precios__minima">
        Estadía mínima: {SITE.ESTADIA_MINIMA_NOCHES} noches · {PRECIOS.descuento}
      </p>
      <p class="precios__nota">{PRECIOS.nota}</p>

      <div class="precios__ctas">
        <a href={SITE.AIRBNB_URL} class="btn btn--outline" target="_blank" rel="noopener noreferrer" data-meta-event="Lead" data-meta-content="airbnb_precios">
          Ver disponibilidad en Airbnb
        </a>
        <a href={SITE.WHATSAPP_URL} class="btn btn--primary" target="_blank" rel="noopener noreferrer" data-meta-event="Contact" data-meta-content="whatsapp_precios">
          Consultar por WhatsApp
        </a>
      </div>
    </div>
  </section>
)}

<style>
.precios {
  background: var(--color-roto);
  padding-block: var(--sp-20);
}

.precios__cards {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  gap: var(--sp-4);
  max-width: 520px;
  margin-inline: auto;
  margin-bottom: var(--sp-6);
}

.precios__card {
  border: 1px solid var(--color-suave);
  border-radius: var(--radius);
  padding: var(--sp-8) var(--sp-6);
  text-align: center;
  background: #fff;
}

.precios__card--dest {
  border-color: var(--color-tierra);
}

.precios__label {
  font-size: var(--text-xs);
  font-weight: 600;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--color-tierra);
  margin-bottom: var(--sp-3);
}

.precios__monto {
  font-family: var(--font-display);
  font-size: var(--text-3xl);
  font-weight: 500;
  color: var(--color-carbon);
  line-height: 1;
}

.precios__unidad {
  font-size: var(--text-xs);
  color: var(--color-tierra);
  opacity: 0.7;
  margin-top: var(--sp-2);
}

.precios__minima {
  text-align: center;
  font-size: var(--text-sm);
  color: var(--color-carbon);
  font-weight: 500;
  margin-top: var(--sp-4);
  margin-bottom: var(--sp-2);
}

.precios__nota {
  text-align: center;
  font-size: var(--text-sm);
  color: rgba(26,26,24,0.5);
  margin-bottom: var(--sp-10);
  max-width: 460px;
  margin-inline: auto;
  line-height: 1.65;
}

.precios__ctas {
  display: flex;
  gap: var(--sp-3);
  justify-content: center;
  flex-wrap: wrap;
}

@media (max-width: 640px) {
  .precios { padding-block: var(--sp-16); }
  .precios__ctas .btn { width: 100%; justify-content: center; }
}
</style>
