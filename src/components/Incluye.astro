---
import { INCLUYE } from '../content/landing';
---

<section class="incluye" id="incluye" aria-labelledby="incluye-titulo">
  <div class="container">
    <div class="section-header">
      <p class="eyebrow eyebrow--light">{INCLUYE.eyebrow}</p>
      <h2 class="section-h2 section-h2--light" id="incluye-titulo">{INCLUYE.titulo}</h2>
    </div>

    <div class="incluye__cols">
      <div class="incluye__col">
        <h3 class="incluye__col-titulo">Interior</h3>
        <ul class="incluye__lista" role="list">
          {INCLUYE.interior.map((item) => <li>{item}</li>)}
        </ul>
      </div>
      <div class="incluye__col">
        <h3 class="incluye__col-titulo">Exterior</h3>
        <ul class="incluye__lista" role="list">
          {INCLUYE.exterior.map((item) => <li>{item}</li>)}
        </ul>
      </div>
      <div class="incluye__col">
        <h3 class="incluye__col-titulo">Acceso y entorno</h3>
        <ul class="incluye__lista" role="list">
          {INCLUYE.acceso.map((item) => <li>{item}</li>)}
        </ul>
      </div>
    </div>
  </div>
</section>

<style>
.incluye {
  background: var(--color-humo);
  padding-block: var(--sp-20);
}

.incluye__cols {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  gap: var(--sp-10);
}

.incluye__col-titulo {
  font-size: var(--text-xs);
  font-weight: 600;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--color-arena);
  margin-bottom: var(--sp-4);
  padding-bottom: var(--sp-2);
  border-bottom: 1px solid rgba(201,185,154,0.2);
}

.incluye__lista {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: var(--sp-2);
}

.incluye__lista li {
  font-size: var(--text-sm);
  color: rgba(247,244,238,0.72);
  line-height: 1.55;
  padding-left: 1.25em;
  position: relative;
}

.incluye__lista li::before {
  content: '–';
  position: absolute;
  left: 0;
  color: var(--color-arena);
  opacity: 0.55;
}

@media (max-width: 640px) {
  .incluye { padding-block: var(--sp-16); }
  .incluye__cols { gap: var(--sp-8); }
}
</style>
