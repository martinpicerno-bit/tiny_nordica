---
import { SITE } from '../data/site';
---

<section class="cta-banner" aria-label="Reservar Tiny Granero">
  <div class="cta-banner__bg" aria-hidden="true"></div>
  <div class="container cta-banner__content">
    <p class="eyebrow eyebrow--light">Empieza aquí</p>
    <h2 class="cta-banner__titulo">¿Listos para escapar?</h2>
    <p class="cta-banner__desc">
      Escríbenos por WhatsApp para consultar disponibilidad o reserva directamente en Airbnb.
    </p>
    <div class="cta-banner__btns">
      <a href={SITE.WHATSAPP_URL} class="btn btn--primary" target="_blank" rel="noopener noreferrer" data-meta-event="Contact" data-meta-content="whatsapp_cta_banner">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
          <path d="M12 0C5.373 0 0 5.373 0 12c0 2.136.561 4.14 1.541 5.872L.057 23.86a.5.5 0 0 0 .614.641l6.178-1.457A11.945 11.945 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.814 9.814 0 0 1-4.983-1.361l-.357-.212-3.67.866.92-3.565-.233-.368A9.807 9.807 0 0 1 2.182 12C2.182 6.57 6.57 2.182 12 2.182S21.818 6.57 21.818 12 17.43 21.818 12 21.818z"/>
        </svg>
        Escribirnos por WhatsApp
      </a>
      <a href={SITE.AIRBNB_URL} class="btn btn--ghost" target="_blank" rel="noopener noreferrer" data-meta-event="Lead" data-meta-content="airbnb_cta_banner">
        Ver disponibilidad en Airbnb
      </a>
    </div>
  </div>
</section>

<style>
.cta-banner {
  position: relative;
  padding-block: var(--sp-20);
  overflow: hidden;
}

.cta-banner__bg {
  position: absolute;
  inset: 0;
  background: var(--color-carbon);
}

.cta-banner__bg::after {
  content: '';
  position: absolute;
  inset: 0;
  background: url('/images/hero.jpg') center / cover no-repeat;
  opacity: 0.1;
}

.cta-banner__content {
  position: relative;
  z-index: 1;
  text-align: center;
}

.cta-banner__titulo {
  font-family: var(--font-display);
  font-size: clamp(var(--text-3xl), 5vw, var(--text-5xl));
  font-weight: 400;
  color: var(--color-roto);
  margin-block: var(--sp-3) var(--sp-4);
  line-height: 1.1;
}

.cta-banner__desc {
  font-size: var(--text-base);
  color: rgba(247,244,238,0.65);
  max-width: 440px;
  margin-inline: auto;
  margin-bottom: var(--sp-10);
  line-height: 1.7;
}

.cta-banner__btns {
  display: flex;
  gap: var(--sp-3);
  justify-content: center;
  flex-wrap: wrap;
}

@media (max-width: 640px) {
  .cta-banner { padding-block: var(--sp-16); }
  .cta-banner__btns { flex-direction: column; align-items: stretch; }
  .cta-banner__btns .btn { justify-content: center; }
}
</style>
