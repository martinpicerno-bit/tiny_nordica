---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Propuesta from '../components/Propuesta.astro';
import Espacio from '../components/Espacio.astro';
import Incluye from '../components/Incluye.astro';
import Precios from '../components/Precios.astro';
import Extras from '../components/Extras.astro';
import Instagram from '../components/Instagram.astro';
import FAQ from '../components/FAQ.astro';
import CTABanner from '../components/CTABanner.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="Tiny Granero · Escapada romántica en Matanzas, Pupuya y Puertecillo"
  description="Tiny house sobre el cerro en Matanzas para escapadas románticas en pareja. Naturaleza, comodidad real y calma total. Reserva en Airbnb o escríbenos por WhatsApp."
  ogTitle="Tiny Granero · Escapada romántica en Matanzas"
  ogDescription="Una tiny house íntima sobre el cerro en Matanzas. Naturaleza, comodidad y calma total para parejas que quieren una pausa real."
  ogImage="/images/hero.jpg"
>
  <main>
    <Hero />
    <Propuesta />
    <Espacio />
    <Incluye />
    <Precios />
    <Extras />
    <Instagram />
    <FAQ />
    <CTABanner />
  </main>
  <Footer />
</BaseLayout>
